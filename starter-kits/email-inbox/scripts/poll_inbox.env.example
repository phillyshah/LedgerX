# Copy to poll_inbox.env (next to poll_inbox.py) and fill in your values.

# IMAP mailbox the script polls
INBOX_IMAP_HOST=imap.hostinger.com
INBOX_IMAP_PORT=993
INBOX_IMAP_USER=receipts@your-domain.com
INBOX_IMAP_PASSWORD=your-mailbox-password

# Edge function endpoint (Supabase deploy URL)
INBOX_FUNCTION_URL=https://YOUR-PROJECT-REF.supabase.co/functions/v1/inbound-email

# Shared secret — must match the INBOUND_EMAIL_SECRET set on the edge function.
# Generate with: openssl rand -hex 32
INBOX_INBOUND_SECRET=replace-with-the-shared-secret

# Optional: max attachment size in bytes (default 10 MB)
# INBOX_MAX_ATTACH_BYTES=10485760
