# Copy to ledgerx-keepalive.env (next to the script) and fill in.
# The anon key is the same one that's already in the deployed dist/, so
# it's safe to keep on the VPS — no service-role secret here.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE

# Optional: override the default log path if /var/log isn't writable.
# LOG_FILE=/opt/ledgerx-keepalive/ledgerx-keepalive.log
